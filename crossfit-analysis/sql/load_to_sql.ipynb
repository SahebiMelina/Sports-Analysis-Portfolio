   "source": [
    "import sqlite3\n",
    "import pandas as pd\n",
    "\n",
    "df = pd.read_csv(\"../data/cleaned_athletes.csv\")\n",
    "\n",
    "conn = sqlite3.connect(\"crossfit.db\")\n",
    "\n",
    "df.to_sql(\"athletes\", conn, if_exists=\"replace\", index=False)\n",
    "\n",
    "print(\"Data loaded into SQLite!\")"
   ]
  }
