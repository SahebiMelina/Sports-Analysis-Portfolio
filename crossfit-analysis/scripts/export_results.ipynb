    "import pandas as pd\n",
    "import sqlite3\n",
    "\n",
    "conn = sqlite3.connect(\"../data/crossfit.db\")\n",
    "\n",
    "df = pd.read_sql(\"SELECT * FROM athlete_strength_analysis\", conn)\n",
    "\n",
    "df.to_csv(\"../outputs/strength_analysis.csv\", index=False)\n",
    "\n",
    "print(\"Export successful!\")"
   ]
  }
